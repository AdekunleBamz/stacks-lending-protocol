{
  "name": "stacks-lending-protocol",
  "version": "1.0.0",
  "description": "A Stacks blockchain-based lending protocol enabling borrowing and lending of STX with collateral management",
  "private": true,
  "scripts": {
    "install:all": "npm install",
    "test": "vitest run",
    "test:watch": "chokidar \"tests/**/*.ts\" \"contracts/**/*.clar\" -c \"npm run test:report\"",
    "test:report": "vitest run -- --coverage --costs",
    "clarinet:check": "clarinet check",
    "clarinet:test": "clarinet test",
    "clarinet:console": "clarinet console"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdekunleBamz/stacks-lending-protocol.git"
  },
  "keywords": [
    "stacks",
    "clarity",
    "blockchain",
    "lending-protocol",
    "defi",
    "smart-contracts",
    "borrowing",
    "collateral"
  ],
  "author": "Adekunle Bamz",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AdekunleBamz/stacks-lending-protocol/issues"
  },
  "homepage": "https://github.com/AdekunleBamz/stacks-lending-protocol#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "dependencies": {
    "@hirosystems/clarinet-sdk": "^3.0.2",
    "@stacks/transactions": "^7.0.6",
    "chokidar-cli": "^3.0.0",
    "vitest": "^3.1.3",
    "vitest-environment-clarinet": "^2.3.0"
  },
  "devDependencies": {
    "@hirosystems/clarinet-sdk-wasm": "^3.7.0",
    "vite": "^7.1.9"
  }
}
